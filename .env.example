# =============================================================================
# Variáveis de ambiente — copie este arquivo para .env e preencha os valores
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# URL do seu projeto Supabase (Painel → Project Settings → API → Project URL)
SUPABASE_URL=https://<seu-projeto>.supabase.co

# Chave anon do projeto (Painel → Project Settings → API → anon public)
# Usada pelo upload_to_supabase.py para autenticar as requisições ao Storage.
# Para produção sem RLS, prefira a service_role key (nunca exponha no cliente).
SUPABASE_ANON_KEY=<sua-chave-anon>

# =============================================================================
# Além do .env, os scripts abaixo têm caminhos locais que precisam ser
# ajustados diretamente no código (seção "Configuração" de cada arquivo):
#
#   optimize_images.py
#     → target_dir : pasta onde estão os PNGs a otimizar
#
#   upload_to_supabase.py
#     → source_dir : pasta com as imagens .webp a enviar para o Supabase
#     → bucket_name: nome do bucket (padrão: "stimuli"; criado automaticamente)
# =============================================================================
